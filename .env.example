# CTFd
CTFD_URL=https://ctf.example.com
CTFD_TOKEN=ctfd_your_api_token_here

# API Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=

# ── Reflection model (cheap model used to distill failed attempts) ──────────
# gpt-4o-mini is default (~$0.001/call). Set to ollama/llama3.1:8b for free.
REFLECTION_MODEL=openai:gpt-4o-mini

# ── Ollama (free local solver, no API cost) ──────────────────────────────────
# Start Ollama: https://ollama.com then: ollama pull qwen2.5-coder:14b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=ollama/qwen2.5-coder:14b
# Optional: override max tool calls per attempt (default 40)
# OLLAMA_MAX_TOOL_CALLS=40

# ── OpenRouter (free-tier cloud models, rate-limited) ────────────────────────
# Get free key: https://openrouter.ai
OPENROUTER_API_KEY=

# ── AWS Bedrock (Claude fallback when claude-sdk hits quota) ────────────────
AWS_REGION=us-east-1
# AWS_BEARER_TOKEN=  # or use ~/.aws/credentials
